# Shared git settings (tracked by yadm, synced across machines)
# Machine-specific settings (user, credentials) stay in ~/.gitconfig

[credential]
	# Use macOS built-in keychain helper by default.
	# Previously used git-credential-manager but gcm 2.7.3's bundled Avalonia
	# UI framework segfaults when macOS Accessibility services query its views
	# (see crash reports in ~/Library/Logs/DiagnosticReports).
	# osxkeychain is macOS-native and sufficient for GitHub HTTPS.
	# Override in ~/.gitconfig on machines needing gcm (Azure DevOps, etc.).
	helper = osxkeychain

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[include]
	path = ~/.config/delta/catppuccin.gitconfig

[delta]
	features = catppuccin-mocha
	navigate = true
	side-by-side = true
	line-numbers = true

[init]
	defaultBranch = main

[merge]
	conflictstyle = zdiff3

# Syntax-aware auto-resolution of merge conflicts (mergiraf.org).
# Registered globally but inert until a repo opts in via .gitattributes,
# e.g.:  *.py merge=mergiraf
[merge "mergiraf"]
	name = mergiraf
	driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L

[push]
	default = current
	autoSetupRemote = true

[pull]
	rebase = true

[branch]
	sort = -committerdate

[diff]
	colorMoved = default
	algorithm = histogram

[blame]
	coloring = highlightRecent

[rerere]
	enabled = true

[column]
	ui = auto

[rebase]
	autostash = true

[fetch]
	prune = true
	writeCommitGraph = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[alias]
	# Semantic diff via difftastic (syntax trees, not lines); the regular
	# 'git diff' keeps delta as its pager — the two complement each other
	dft = !git -c diff.external=difft diff
