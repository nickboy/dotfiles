#!/usr/bin/env bash
# Yadm bootstrap script - runs after cloning dotfiles

set -e

echo "🚀 Starting yadm bootstrap..."

# Create necessary directories
echo "📁 Creating required directories..."
mkdir -p ~/.config
mkdir -p ~/.local/bin
mkdir -p ~/Library/LaunchAgents

# Setup Ghostty configuration symlink
echo "👻 Setting up Ghostty configuration..."
if [ -f "$HOME/.config/ghostty/config" ]; then
    GHOSTTY_APP_CONFIG="$HOME/Library/Application Support/com.mitchellh.ghostty"

    # Create Ghostty app config directory if it doesn't exist
    mkdir -p "$GHOSTTY_APP_CONFIG"

    # Remove existing config if it's not a symlink
    if [ -f "$GHOSTTY_APP_CONFIG/config" ] && [ ! -L "$GHOSTTY_APP_CONFIG/config" ]; then
        echo "  Backing up existing Ghostty config..."
        mv "$GHOSTTY_APP_CONFIG/config" "$GHOSTTY_APP_CONFIG/config.backup.$(date +%s)"
    fi

    # Create symlink if it doesn't exist
    if [ ! -L "$GHOSTTY_APP_CONFIG/config" ]; then
        echo "  Creating symlink for Ghostty config..."
        ln -sf "$HOME/.config/ghostty/config" "$GHOSTTY_APP_CONFIG/config"
    else
        echo "  Ghostty symlink already exists"
    fi

    # Create symlink for shaders directory if it exists
    if [ -d "$HOME/.config/ghostty/shaders" ]; then
        if [ ! -L "$GHOSTTY_APP_CONFIG/shaders" ]; then
            echo "  Creating symlink for Ghostty shaders..."
            ln -sf "$HOME/.config/ghostty/shaders" "$GHOSTTY_APP_CONFIG/shaders"
        else
            echo "  Ghostty shaders symlink already exists"
        fi
    fi
else
    echo "  Warning: Ghostty config not found in ~/.config/ghostty/"
fi

# Install Homebrew if not present
if ! command -v brew &> /dev/null; then
    echo "🍺 Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    # Add Homebrew to PATH for Apple Silicon
    if [ -f "/opt/homebrew/bin/brew" ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    fi
fi

# Install Brewfile packages
if [ -f "$HOME/Brewfile" ] && command -v brew &> /dev/null; then
    echo "📦 Installing Brewfile packages..."
    echo "  Note: Some casks may require sudo password. Run 'brew bundle' manually if needed."
    brew bundle --file="$HOME/Brewfile" || true
fi

# Install mise-managed runtimes defined in ~/.config/mise/config.toml
# (node, python, ruby, go). Without this step, `mise ls` shows "(missing)"
# on a fresh clone and userland falls back to brew's runtimes only.
if command -v mise &> /dev/null; then
    echo "🧰 Installing mise-managed runtimes..."
    mise install || echo "  ⚠️  Some mise runtimes failed to install"
else
    echo "  ⚠️  mise not found, skipping runtime install"
fi

# Install tree-sitter-cli (required for nvim-treesitter main branch)
# Note: Homebrew's tree-sitter is just a library, not the CLI
if command -v cargo &> /dev/null; then
    if ! command -v tree-sitter &> /dev/null; then
        echo "🌳 Installing tree-sitter-cli via cargo..."
        cargo install --locked tree-sitter-cli || echo "  ⚠️  Failed to install tree-sitter-cli"
    else
        echo "🌳 tree-sitter-cli already installed"
    fi
else
    echo "  ⚠️  cargo not found, skipping tree-sitter-cli installation"
    echo "     Run 'cargo install --locked tree-sitter-cli' manually after installing Rust"
fi

# Install bob (Neovim version manager) from git dev branch.
# We intentionally track upstream dev instead of Homebrew or crates.io:
# the dev branch contains the nvim proxy permission fix (issue #241) that
# hasn't shipped in any tagged release yet. The daily maintenance script
# keeps bob in sync with dev via SHA-cached cargo rebuilds.
if command -v cargo &> /dev/null; then
    if [ ! -x "$HOME/.cargo/bin/bob" ]; then
        echo "🤖 Installing bob from MordechaiHadad/bob dev branch..."
        cargo install --git https://github.com/MordechaiHadad/bob \
            --branch dev --locked \
            || echo "  ⚠️  Failed to install bob"
        # Seed the SHA cache so the first maintenance run is a no-op.
        if command -v bob &> /dev/null && [ -x "$HOME/.cargo/bin/bob" ]; then
            mkdir -p "$HOME/.cache/dotfiles"
            git ls-remote https://github.com/MordechaiHadad/bob.git refs/heads/dev \
                2>/dev/null | awk '{print $1}' > "$HOME/.cache/dotfiles/bob-dev-sha" \
                || rm -f "$HOME/.cache/dotfiles/bob-dev-sha"
        fi
    else
        echo "🤖 bob already installed at ~/.cargo/bin/bob"
    fi
else
    echo "  ⚠️  cargo not found, skipping bob installation"
fi

# Setup tmux plugin manager
if [ ! -d "$HOME/.tmux/plugins/tpm" ]; then
    echo "🔌 Installing tmux plugin manager..."
    git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
fi

# Install tmux plugins automatically
echo "📦 Installing tmux plugins..."
if [ -f "$HOME/.tmux/plugins/tpm/bin/install_plugins" ]; then
    "$HOME/.tmux/plugins/tpm/bin/install_plugins"
else
    echo "  Note: Run 'Ctrl-A + I' inside tmux to install plugins"
fi

# Install Zinit if not present
if [ ! -d "$HOME/.local/share/zinit/zinit.git" ]; then
    echo "⚡ Installing Zinit..."
    bash -c "$(curl --fail --show-error --silent --location https://raw.githubusercontent.com/zdharma-continuum/zinit/HEAD/scripts/install.sh)"
fi

# Clear zinit snippet cache to ensure fresh state (prevents OMZ loading issues)
echo "🧹 Clearing zinit snippet cache..."
rm -rf "$HOME/.local/share/zinit/snippets/OMZ"* "$HOME/.zcompdump"* 2>/dev/null || true

# Install/Update Catppuccin themes (always fetch latest)
echo "🎨 Installing/Updating Catppuccin themes..."

# FZF Catppuccin theme
echo "  Downloading FZF Catppuccin Mocha theme..."
mkdir -p ~/.config/fzf
curl -sL -o ~/.config/fzf/catppuccin-mocha.sh \
    https://raw.githubusercontent.com/catppuccin/fzf/main/themes/catppuccin-fzf-mocha.sh || \
    echo "    ⚠️  Failed to download FZF theme"

# Bat Catppuccin theme
echo "  Downloading Bat Catppuccin Mocha theme..."
BAT_CONFIG_DIR="$(bat --config-dir 2>/dev/null || echo "$HOME/.config/bat")"
BAT_THEME_DIR="$BAT_CONFIG_DIR/themes"
mkdir -p "$BAT_THEME_DIR"
# Create syntaxes directory to avoid warning
mkdir -p "$BAT_CONFIG_DIR/syntaxes"
curl -sL -o "$BAT_THEME_DIR/Catppuccin Mocha.tmTheme" \
    "https://github.com/catppuccin/bat/raw/main/themes/Catppuccin%20Mocha.tmTheme" || \
    echo "    ⚠️  Failed to download Bat theme"
# Rebuild bat cache if bat is installed
if command -v bat &> /dev/null; then
    bat cache --build >/dev/null 2>&1 || echo "    ⚠️  Failed to rebuild bat cache"
fi

# Delta Catppuccin theme
echo "  Downloading Delta Catppuccin theme..."
mkdir -p ~/.config/delta
curl -sL -o ~/.config/delta/catppuccin.gitconfig \
    https://raw.githubusercontent.com/catppuccin/delta/main/catppuccin.gitconfig || \
    echo "    ⚠️  Failed to download Delta theme"

# Eza Catppuccin theme (for macOS)
echo "  Downloading Eza Catppuccin Mocha theme..."
if [[ "$OSTYPE" == "darwin"* ]]; then
    EZA_CONFIG="$HOME/Library/Application Support/eza"
else
    EZA_CONFIG="$HOME/.config/eza"
fi
mkdir -p "$EZA_CONFIG"
curl -sL -o "$EZA_CONFIG/theme.yml" \
    https://raw.githubusercontent.com/catppuccin/eza/main/themes/mocha/catppuccin-mocha-mauve.yml || \
    echo "    ⚠️  Failed to download Eza theme"

# Atuin Catppuccin theme
echo "  Downloading Atuin Catppuccin Mocha theme..."
mkdir -p ~/.config/atuin/themes
curl -sL -o ~/.config/atuin/themes/catppuccin-mocha-blue.toml \
    https://raw.githubusercontent.com/catppuccin/atuin/main/themes/mocha/catppuccin-mocha-blue.toml || \
    echo "    ⚠️  Failed to download Atuin theme"

# btop Catppuccin theme
echo "  Downloading btop Catppuccin Mocha theme..."
mkdir -p ~/.config/btop/themes
curl -sL -o ~/.config/btop/themes/catppuccin_mocha.theme \
    https://raw.githubusercontent.com/catppuccin/btop/main/themes/catppuccin_mocha.theme || \
    echo "    ⚠️  Failed to download btop theme"

# Install yazi packages (plugins and flavors from package.toml)
if command -v ya &> /dev/null; then
    echo "📂 Installing yazi packages..."
    ya pkg install || echo "  ⚠️  Failed to install yazi packages"
else
    echo "  ⚠️  ya not found, skipping yazi package installation"
    echo "     Install yazi first, then run 'ya pkg install' manually"
fi

# Install daily maintenance automation
if [ -f "$HOME/install-daily-maintenance.sh" ]; then
    echo "🔧 Setting up daily maintenance automation..."
    bash "$HOME/install-daily-maintenance.sh"
fi

# Make all scripts executable
echo "🔐 Setting executable permissions..."
chmod +x ~/daily-maintenance*.sh 2>/dev/null || true
chmod +x ~/install-daily-maintenance.sh 2>/dev/null || true
chmod +x ~/uninstall-daily-maintenance.sh 2>/dev/null || true
chmod +x ~/test-dotfiles.sh 2>/dev/null || true
chmod +x ~/.local/bin/* 2>/dev/null || true

# Install essential treesitter parsers for Neovim
if command -v nvim &> /dev/null; then
    echo "🌲 Installing essential treesitter parsers..."
    # These parsers are required by noice.nvim and common development
    # vim, regex, lua, bash - required by noice.nvim cmdline
    # markdown, markdown_inline - required by noice.nvim for LSP docs
    # python, json, yaml, toml - common development languages
    # Use gtimeout (macOS) or timeout (Linux) if available
    TIMEOUT_CMD=""
    if command -v gtimeout &> /dev/null; then
        TIMEOUT_CMD="gtimeout 120"
    elif command -v timeout &> /dev/null; then
        TIMEOUT_CMD="timeout 120"
    fi
    $TIMEOUT_CMD nvim --headless \
        "+TSInstall vim regex lua bash markdown markdown_inline python json yaml toml" \
        "+sleep 20" +qa 2>/dev/null || echo "  ⚠️  Some parsers may need manual installation"
    echo "  ✓ Treesitter parsers installed"
fi

echo "✅ Bootstrap complete!"
echo ""
echo "📝 Next steps:"
echo "  1. Restart your terminal or run: source ~/.zshrc"
echo "  2. Open Neovim to verify LazyVim plugins are installed"
echo "  3. Check daily maintenance status: ~/daily-maintenance-control.sh status"