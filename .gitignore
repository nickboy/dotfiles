.DS_Store

# Git configuration (machine-specific)
.gitconfig

# Claude Code local settings (machine-specific permissions)
.claude/settings.local.json

.bin/assets/corona
.config/vifm/vifminfo
vim/plugged/
vim/undodir/
git/gitconfig.local.symlink
Brewfile.lock.json

# Generated files from templates
Library/LaunchAgents/com.daily-maintenance.plist

# Neovim auto-generated files
.config/nvim/lazy-lock.json

# Yazi vendor files (managed by ya pkg, not yadm)
.config/yazi/plugins/*/
.config/yazi/flavors/*/

# Zellij WASM plugins (binary, install separately)
.config/zellij/plugins/*.wasm

# Atuin theme (downloaded by bootstrap)
.config/atuin/themes/

# btop theme (downloaded by bootstrap)
.config/btop/themes/
